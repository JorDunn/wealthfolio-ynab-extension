{
  "name": "wealthfolio-ynab-sync-addon",
  "version": "0.1.0",
  "description": "YNAB transaction sync addon for Wealthfolio",
  "type": "module",
  "main": "dist/addon.js",
  "keywords": [
    "wealthfolio",
    "addon",
    "ynab",
    "sync"
  ],
  "license": "AGPL-3.0-only",
  "author": "Jordan Dunn / NodeTwo",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:server": "wealthfolio dev",
    "test": "vitest",
    "clean": "rm -rf dist",
    "package": "mkdir -p dist && find dist -name '*.map' -delete && rm -f dist/*.zip && zip -r dist/$npm_package_name-$npm_package_version.zip manifest.json dist/ README.md -x '*.map'",
    "bundle": "npm run clean && npm run build && npm run package",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.90.0",
    "@wealthfolio/addon-sdk": "^3.6.2",
    "@wealthfolio/ui": "^3.6.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-query": "^5.90.20",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.2",
    "@wealthfolio/addon-dev-tools": "^3.6.2",
    "@wealthfolio/addon-sdk": "^3.6.2",
    "@wealthfolio/ui": "^3.6.0",
    "date-fns": "^4.1.0",
    "jsdom": "29.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^2.1.8"
  }
}
